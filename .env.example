# === QueueLess Backend — Production Environment Variables ===

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL (Supabase or any PostgreSQL provider)
DB_HOST=db.xxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password

# Redis (Upstash or any Redis provider)
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# JWT Secret (generate with: openssl rand -base64 64)
JWT_SECRET=your-64-character-random-secret-key-here

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://your-app.vercel.app,https://queueless.in

# Razorpay (test keys for development, live keys for production)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# SMS — MSG91 (optional, leave empty to disable)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Object Storage — MinIO / Supabase Storage / S3-compatible
MINIO_ENDPOINT=https://your-storage-endpoint
MINIO_ACCESS=your-access-key
MINIO_SECRET=your-secret-key
MINIO_BUCKET=attachments

# === Supabase Storage (primary) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-service-role-key
SUPABASE_STORAGE_BUCKET=attachments

# === Cloudinary (fallback) ===
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Storage provider config (supabase or cloudinary)
STORAGE_PRIMARY=supabase
STORAGE_FALLBACK=cloudinary

# === Email — MailerSend ===
MAILERSEND_API_KEY=mlsn.your-api-key-here
EMAIL_FROM=noreply@queueless.in
EMAIL_ENABLED=true

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gemini AI (optional — for no-show prediction)
GEMINI_API_KEY=

# Server port (Render sets this automatically)
PORT=8080
